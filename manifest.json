{
  "manifest_version": 3,
  "name": "MultiChat",
  "version": "0.2.0",
  "description": "同时和多个 AI 对话的聊天聚合器",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://*.gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://*.chat.deepseek.com/*",
    "https://claude.ai/*",
    "https://*.claude.ai/*",
    "https://grok.com/*",
    "https://*.grok.com/*",
    "https://www.doubao.com/*",
    "https://*.doubao.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://chatgpt.com https://*.chatgpt.com https://chat.openai.com https://gemini.google.com https://*.gemini.google.com https://chat.deepseek.com https://*.chat.deepseek.com https://claude.ai https://*.claude.ai https://grok.com https://*.grok.com https://www.doubao.com https://*.doubao.com;"
  },
  "action": {
    "default_title": "MultiChat"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://gemini.google.com/*",
        "*://*.gemini.google.com/*",
        "*://chat.deepseek.com/*",
        "*://*.chat.deepseek.com/*",
        "*://claude.ai/*",
        "*://*.claude.ai/*",
        "*://grok.com/*",
        "*://*.grok.com/*",
        "*://www.doubao.com/*",
        "*://*.doubao.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "chaojia-frame-rules",
        "enabled": true,
        "path": "frame-rules.json"
      }
    ]
  }
}
